# --- ToCodex API relay configuration ----------------------------------------

# Upstream base URL (extension default: https://api.tocodex.com). The relay
# automatically normalizes so clients may call /v1/chat/completions directly.
TOCODEX_API_URL=https://api.tocodex.com

# HMAC secret used to sign requests. Defaults to the string hard-coded in the
# extension (`tc-hmac-s3cr3t-k3y-2026-tocodex-platform`). Override in prod
# once the real server secret is known.
TOCODEX_HMAC_SECRET=tc-hmac-s3cr3t-k3y-2026-tocodex-platform

# Optional: pre-configure the upstream bearer token (a ToCodex session token).
# When set, the relay ignores client-supplied Authorization headers and always
# uses this value. Leave empty to require clients to pass their own token.
TOCODEX_API_KEY=

# Paths that must carry the dynamic signature (comma-separated).
# Matches what the ToCodex extension actually signs.
TOCODEX_SIGNED_PATHS=/v1/chat/completions

# Set to "true" to sign every forwarded path (useful for experimentation).
TOCODEX_SIGN_ALL_PATHS=false

# App version placed in X-Roo-App-Version and User-Agent.
TOCODEX_APP_VERSION=3.1.3

# --- Listener ---------------------------------------------------------------
LISTEN_HOST=0.0.0.0
PORT=8787
HEALTH_PATH=/_health
UPSTREAM_TIMEOUT_MS=600000

# --- CORS -------------------------------------------------------------------
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_HEADERS=Content-Type, Authorization
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
